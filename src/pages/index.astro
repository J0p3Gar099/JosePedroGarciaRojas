---
import Layout from '../layouts/Layout.astro'
---
<Layout title="Jose Pedro Garcia — Backend Dev">

<!-- NAV -->
<nav style="position:fixed;top:0;left:0;right:0;z-index:100;padding:1.5rem 2.5rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid transparent;transition:border-color 0.3s,background 0.3s" id="nav">
  <span style="font-family:var(--font-mono);font-size:12px;color:var(--muted);letter-spacing:0.1em">JPG.dev</span>
  <div style="display:flex;gap:2rem">
    <a href="#experiencia" style="font-size:13px;color:var(--muted);transition:color 0.2s" onmouseenter="this.style.color='var(--text)'" onmouseleave="this.style.color='var(--muted)'">Experiencia</a>
    <a href="#skills" style="font-size:13px;color:var(--muted);transition:color 0.2s" onmouseenter="this.style.color='var(--text)'" onmouseleave="this.style.color='var(--muted)'">Skills</a>
    <a href="#contacto" style="font-size:13px;color:var(--muted);transition:color 0.2s" onmouseenter="this.style.color='var(--text)'" onmouseleave="this.style.color='var(--muted)'">Contacto</a>
  </div>
</nav>

<!-- HERO -->
<section style="min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 2.5rem 5rem;position:relative;overflow:hidden">

  <!-- Background grid -->
  <div style="position:absolute;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:80px 80px;opacity:0.4;pointer-events:none"></div>

  <!-- Accent glow -->
  <div style="position:absolute;top:20%;right:10%;width:400px;height:400px;background:radial-gradient(circle,rgba(200,240,100,0.06) 0%,transparent 70%);pointer-events:none"></div>

  <div style="position:relative;max-width:900px">
    <p class="reveal" data-delay="100" style="font-family:var(--font-mono);font-size:12px;color:var(--accent);letter-spacing:0.15em;margin-bottom:1.5rem">— Desarrollador Backend · .NET / C#</p>

    <h1 style="font-family:var(--font-serif);font-size:clamp(3.5rem,8vw,7rem);line-height:1.05;font-weight:400;margin-bottom:1.5rem">
      <span class="reveal" data-delay="150" style="display:block">Jose Pedro</span>
      <span class="reveal" data-delay="250" style="display:block;color:var(--muted)">Garcia Rojas</span>
    </h1>

    <p class="reveal" data-delay="380" style="max-width:540px;color:var(--muted);font-size:16px;line-height:1.8;margin-bottom:3rem">
      Más de <span style="color:var(--text)">4 años</span> construyendo sistemas empresariales robustos. Especializado en APIs REST, optimización SQL y arquitecturas escalables en <span style="color:var(--text)">.NET / C#</span>.
    </p>

    <div class="reveal" data-delay="480" style="display:flex;gap:1rem;align-items:center;flex-wrap:wrap">
      <a href="mailto:josepedrogr.99@gmail.com" style="display:inline-flex;align-items:center;gap:8px;padding:0.75rem 1.5rem;background:var(--accent);color:#0a0a0a;font-size:13px;font-weight:500;border-radius:2px;transition:opacity 0.2s" onmouseenter="this.style.opacity='0.85'" onmouseleave="this.style.opacity='1'">
        Contactar
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <span style="font-family:var(--font-mono);font-size:12px;color:var(--muted)">55 3653 8782</span>
    </div>
  </div>

  <!-- Scroll hint -->
  <div style="position:absolute;bottom:2.5rem;right:2.5rem;display:flex;flex-direction:column;align-items:center;gap:8px">
    <span style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.15em;writing-mode:vertical-rl">SCROLL</span>
    <div style="width:1px;height:48px;background:linear-gradient(to bottom,var(--muted),transparent)"></div>
  </div>
</section>

<!-- ABOUT STRIP -->
<section style="padding:4rem 2.5rem;border-top:1px solid var(--border);display:flex;gap:4rem;align-items:flex-start;flex-wrap:wrap">
  <div class="reveal" style="flex:0 0 180px">
    <p style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.15em;margin-bottom:0.75rem">UBICACIÓN</p>
    <p style="font-size:14px">Cuautitlán, México</p>
  </div>
  <div class="reveal" data-delay="80" style="flex:0 0 180px">
    <p style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.15em;margin-bottom:0.75rem">EDUCACIÓN</p>
    <p style="font-size:14px">Ing. Sistemas Computacionales</p>
    <p style="font-size:12px;color:var(--muted)">TESCI · 2024</p>
  </div>
  <div class="reveal" data-delay="160" style="flex:0 0 180px">
    <p style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.15em;margin-bottom:0.75rem">EXPERIENCIA</p>
    <p style="font-size:14px">4+ años</p>
    <p style="font-size:12px;color:var(--muted)">Backend · Sistemas empresariales</p>
  </div>
  <div class="reveal" data-delay="240" style="flex:0 0 180px">
    <p style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.15em;margin-bottom:0.75rem">IDIOMAS</p>
    <p style="font-size:14px">Español · Inglés técnico</p>
  </div>
</section>

<!-- EXPERIENCIA -->
<section id="experiencia" style="padding:6rem 2.5rem;border-top:1px solid var(--border)">
  <div style="max-width:900px;margin:0 auto">

    <div class="reveal" style="display:flex;align-items:center;gap:1.5rem;margin-bottom:4rem">
      <p style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.15em">02 — EXPERIENCIA</p>
      <div style="flex:1;height:1px;background:var(--border)"></div>
    </div>

    <!-- Job 1 -->
    <article class="reveal" style="display:grid;grid-template-columns:200px 1fr;gap:3rem;padding:2.5rem 0;border-bottom:1px solid var(--border)">
      <div>
        <p style="font-family:var(--font-mono);font-size:11px;color:var(--accent);margin-bottom:0.5rem">May 2024 — Dic 2025</p>
        <p style="font-size:14px;font-weight:400;margin-bottom:0.25rem">Goncalves</p>
        <p style="font-size:12px;color:var(--muted)">Tepotzotlán, México</p>
      </div>
      <div>
        <h3 style="font-family:var(--font-serif);font-size:1.6rem;font-weight:400;margin-bottom:1rem">Desarrollador C# / .NET</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:0.6rem">
          {[
            ['APIs REST', 'Diseño e implementación reduciendo tiempos de integración ~25%'],
            ['PL/SQL', 'Optimización de consultas, reduciendo tiempos de respuesta 30–40%'],
            ['ASP.NET Core', 'Desarrollo de funcionalidades backend en sistemas críticos multiárea'],
            ['Producción', 'Mantenimiento correctivo reduciendo tiempos de resolución 20%'],
            ['Calidad', 'Integración de nuevas funcionalidades reduciendo errores ~15%'],
          ].map(([tag, desc]) => (
            <li style="display:flex;gap:0.75rem;align-items:baseline;font-size:14px;color:var(--muted)">
              <span style="font-family:var(--font-mono);font-size:10px;color:var(--accent);flex-shrink:0;margin-top:3px">{tag}</span>
              <span>{desc}</span>
            </li>
          ))}
        </ul>
      </div>
    </article>

    <!-- Job 2 -->
    <article class="reveal" data-delay="100" style="display:grid;grid-template-columns:200px 1fr;gap:3rem;padding:2.5rem 0;border-bottom:1px solid var(--border)">
      <div>
        <p style="font-family:var(--font-mono);font-size:11px;color:var(--accent);margin-bottom:0.5rem">Jul 2023 — Jul 2024</p>
        <p style="font-size:14px;font-weight:400;margin-bottom:0.25rem">DITER</p>
        <p style="font-size:12px;color:var(--muted)">Cuautitlán Izcalli, México</p>
      </div>
      <div>
        <h3 style="font-family:var(--font-serif);font-size:1.6rem;font-weight:400;margin-bottom:1rem">Desarrollador Web (Backend)</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:0.6rem">
          {[
            ['Java / Spring', 'Backend con lógica de negocio para procesos operativos críticos, +20% eficiencia'],
            ['Angular', 'Interfaces dinámicas integradas con APIs REST, reduciendo tiempos de interacción'],
            ['MS Access', 'Optimización de consultas y gestión de base de datos, -15% tiempos de carga'],
            ['Agile', 'Metodologías ágiles contribuyendo a reducir tiempos de desarrollo ~20%'],
          ].map(([tag, desc]) => (
            <li style="display:flex;gap:0.75rem;align-items:baseline;font-size:14px;color:var(--muted)">
              <span style="font-family:var(--font-mono);font-size:10px;color:var(--accent2);flex-shrink:0;margin-top:3px">{tag}</span>
              <span>{desc}</span>
            </li>
          ))}
        </ul>
      </div>
    </article>

    <!-- Job 3 -->
    <article class="reveal" data-delay="200" style="display:grid;grid-template-columns:200px 1fr;gap:3rem;padding:2.5rem 0">
      <div>
        <p style="font-family:var(--font-mono);font-size:11px;color:var(--accent);margin-bottom:0.5rem">Mar 2021 — Nov 2023</p>
        <p style="font-size:14px;font-weight:400;margin-bottom:0.25rem">Freelance</p>
        <p style="font-size:12px;color:var(--muted)">Remoto</p>
      </div>
      <div>
        <h3 style="font-family:var(--font-serif);font-size:1.6rem;font-weight:400;margin-bottom:1rem">Desarrollo Backend & Web</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:0.6rem">
          {[
            ['End-to-end', 'Levantamiento de requerimientos y diseño de soluciones, -25% retrabajos'],
            ['Performance', 'Mejoras de rendimiento logrando incrementos de velocidad de carga hasta 30%'],
            ['UX', 'Optimización de experiencia de usuario, reduciendo incidencias reportadas'],
          ].map(([tag, desc]) => (
            <li style="display:flex;gap:0.75rem;align-items:baseline;font-size:14px;color:var(--muted)">
              <span style="font-family:var(--font-mono);font-size:10px;color:var(--muted);flex-shrink:0;margin-top:3px">{tag}</span>
              <span>{desc}</span>
            </li>
          ))}
        </ul>
      </div>
    </article>

  </div>
</section>

<!-- SKILLS -->
<section id="skills" style="padding:6rem 2.5rem;border-top:1px solid var(--border);background:var(--surface)">
  <div style="max-width:900px;margin:0 auto">

    <div class="reveal" style="display:flex;align-items:center;gap:1.5rem;margin-bottom:4rem">
      <p style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.15em">03 — TECNOLOGÍAS</p>
      <div style="flex:1;height:1px;background:var(--border)"></div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2px">
      {[
        { cat: 'Lenguajes',     items: ['C#', 'SQL', 'Java', 'JavaScript'] },
        { cat: 'Backend',       items: ['ASP.NET Core', 'Web API', '.NET Core', 'Spring Boot'] },
        { cat: 'Frontend',      items: ['Angular', 'HTML', 'CSS / SASS', 'TypeScript'] },
        { cat: 'Bases de datos',items: ['SQL Server', 'Oracle', 'PL/SQL', 'MS Access'] },
        { cat: 'Arquitectura',  items: ['APIs REST', 'N-Tier', 'Microservicios'] },
        { cat: 'Herramientas',  items: ['Git', 'Azure DevOps', 'Figma'] },
      ].map((group, gi) => (
        <div class="reveal" data-delay={gi * 60} style="background:var(--bg);padding:1.75rem;border:1px solid var(--border)">
          <p style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.12em;margin-bottom:1rem">{group.cat.toUpperCase()}</p>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:0.5rem">
            {group.items.map(item => (
              <li style="font-size:14px;color:var(--text);display:flex;align-items:center;gap:8px">
                <span style="width:4px;height:4px;background:var(--accent);border-radius:50%;flex-shrink:0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>

<!-- MÉTRICAS -->
<section style="padding:6rem 2.5rem;border-top:1px solid var(--border)">
  <div style="max-width:900px;margin:0 auto">

    <div class="reveal" style="display:flex;align-items:center;gap:1.5rem;margin-bottom:4rem">
      <p style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.15em">04 — IMPACTO</p>
      <div style="flex:1;height:1px;background:var(--border)"></div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:2px">
      {[
        { n: '30–40%', label: 'reducción en tiempos de consultas SQL' },
        { n: '25%',    label: 'menos tiempo de integración entre módulos' },
        { n: '20%',    label: 'reducción en tiempo de resolución de incidencias' },
        { n: '4+',     label: 'años de experiencia en sistemas empresariales' },
      ].map((m, i) => (
        <div class="reveal" data-delay={i * 80} style="padding:2rem 1.5rem;border:1px solid var(--border);position:relative;overflow:hidden">
          <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),transparent)"></div>
          <p style="font-family:var(--font-serif);font-size:2.5rem;font-weight:400;color:var(--accent);margin-bottom:0.75rem;line-height:1">{m.n}</p>
          <p style="font-size:13px;color:var(--muted);line-height:1.5">{m.label}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<!-- CONTACTO -->
<section id="contacto" style="padding:6rem 2.5rem 8rem;border-top:1px solid var(--border);background:var(--surface)">
  <div style="max-width:900px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center">

    <div>
      <p class="reveal" style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.15em;margin-bottom:1.5rem">05 — CONTACTO</p>
      <h2 class="reveal" data-delay="100" style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,3.5rem);font-weight:400;line-height:1.1;margin-bottom:1.5rem">
        Hablemos de<br/><em>tu próximo proyecto.</em>
      </h2>
      <p class="reveal" data-delay="200" style="color:var(--muted);font-size:14px;max-width:360px">
        Disponible para oportunidades full-time o proyectos freelance. Enfocado en backend robusto y APIs de alto rendimiento.
      </p>
    </div>

    <div class="reveal" data-delay="150" style="display:flex;flex-direction:column;gap:1rem">
      <a href="mailto:josepedrogr.99@gmail.com" style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border:1px solid var(--border);transition:border-color 0.2s,background 0.2s" onmouseenter="this.style.borderColor='var(--accent)';this.style.background='rgba(200,240,100,0.04)'" onmouseleave="this.style.borderColor='var(--border)';this.style.background='transparent'">
        <div>
          <p style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.12em;margin-bottom:2px">EMAIL</p>
          <p style="font-size:14px">josepedrogr.99@gmail.com</p>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>

      <div style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border:1px solid var(--border)">
        <div>
          <p style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.12em;margin-bottom:2px">TELÉFONO</p>
          <p style="font-size:14px">55 3653 8782</p>
        </div>
      </div>

      <div style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border:1px solid var(--border)">
        <div>
          <p style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.12em;margin-bottom:2px">UBICACIÓN</p>
          <p style="font-size:14px">Cuautitlán, Estado de México</p>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- FOOTER -->
<footer style="padding:2rem 2.5rem;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
  <span style="font-family:var(--font-mono);font-size:11px;color:var(--muted)">© 2026 Jose Pedro Garcia Rojas</span>
  <span style="font-family:var(--font-mono);font-size:11px;color:var(--muted)">Backend Developer · .NET / C#</span>
</footer>

<script>
  // Navbar scroll effect
  const nav = document.getElementById('nav')
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      nav.style.borderBottomColor = 'var(--border)'
      nav.style.background = 'rgba(10,10,10,0.92)'
      nav.style.backdropFilter = 'blur(12px)'
    } else {
      nav.style.borderBottomColor = 'transparent'
      nav.style.background = 'transparent'
      nav.style.backdropFilter = 'none'
    }
  })
</script>

</Layout>
