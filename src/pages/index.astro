---
import Layout from '../layouts/Layout.astro'
const iconMap = {
  'C#': 'csharp',
  'SQL': 'postgresql',
  'Java': 'java',
  'JavaScript': 'javascript',
  'ASP.NET Core': 'dotnet',
  'Web API': 'dotnet',
  '.NET Core': 'dotnet',
  'Spring Boot': 'springboot',
  'Angular': 'angular',
  'HTML': 'html5',
  'CSS / SASS': 'sass',
  'TypeScript': 'typescript',
  'SQL Server': 'microsoftsqlserver',
  'Oracle': 'oracle',
  'PL/SQL': 'oracle',
  'APIs REST': 'fastapi',
  'N-Tier': 'dotnet',
  'Microservicios': 'docker',
  'Git': 'git',
  'Azure DevOps': 'azuredevops',
  'Figma': 'figma'
}
declare global {
  interface Window {
    toggleMenu: () => void
    closeMobileMenu: () => void
  }
}

---
<Layout title="Jose Pedro Garcia — Backend Dev">

  
<style>
  /* ── NAV ── */
  nav { position:fixed;top:0;left:0;right:0;z-index:100;padding:1.25rem 2.5rem;display:flex;justify-content:space-between;align-items:center;transition:border-color .3s,background .3s }
  .nav-links { display:flex;gap:2rem }
  .nav-links a { font-size:13px;color:var(--muted);transition:color .2s }
  .nav-links a:hover { color:var(--text) }
  .nav-logo { font-family:var(--font-mono);font-size:12px;color:var(--muted);letter-spacing:.1em }

  /* ── HERO ── */
  .hero { min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 2.5rem 5rem;position:relative;overflow:hidden }
  .hero-grid { position:absolute;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:80px 80px;opacity:.4;pointer-events:none }
  .hero-glow { position:absolute;top:20%;right:10%;width:400px;height:400px;background:radial-gradient(circle,rgba(200,240,100,.06) 0%,transparent 70%);pointer-events:none }
  .hero-content { position:relative;max-width:900px }
  .hero-tag { font-family:var(--font-mono);font-size:12px;color:var(--accent);letter-spacing:.15em;margin-bottom:1.5rem }
  .hero-title { font-family:var(--font-serif);font-size:clamp(3rem,8vw,7rem);line-height:1.05;font-weight:400;margin-bottom:1.5rem }
  .hero-title span { display:block }
  .hero-desc { max-width:540px;color:var(--muted);font-size:16px;line-height:1.8;margin-bottom:3rem }
  .hero-actions { display:flex;gap:1rem;align-items:center;flex-wrap:wrap }
  .btn-primary { display:inline-flex;align-items:center;gap:8px;padding:.75rem 1.5rem;background:var(--accent);color:#0a0a0a;font-size:13px;font-weight:500;border-radius:2px;transition:opacity .2s }
  .btn-primary:hover { opacity:.85 }
  .hero-phone { font-family:var(--font-mono);font-size:12px;color:var(--muted) }
  .hero-scroll { position:absolute;bottom:2.5rem;right:2.5rem;display:flex;flex-direction:column;align-items:center;gap:8px }
  .hero-scroll span { font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:.15em;writing-mode:vertical-rl }
  .hero-scroll-line { width:1px;height:48px;background:linear-gradient(to bottom,var(--muted),transparent) }

  /* ── ABOUT STRIP ── */
  .about { padding:4rem 2.5rem;border-top:1px solid var(--border);display:flex;gap:3rem;flex-wrap:wrap }
  .about-item { flex:0 0 170px }
  .about-label { font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:.15em;margin-bottom:.5rem }
  .about-val { font-size:14px }
  .about-sub { font-size:12px;color:var(--muted) }

  /* ── SECTION HEADER ── */
  .sec-header { display:flex;align-items:center;gap:1.5rem;margin-bottom:4rem }
  .sec-tag { font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:.15em;white-space:nowrap }
  .sec-line { flex:1;height:1px;background:var(--border) }

  /* ── EXPERIENCIA ── */
  .exp-section { padding:6rem 2.5rem;border-top:1px solid var(--border) }
  .exp-inner { max-width:900px;margin:0 auto }
  .exp-article { display:grid;grid-template-columns:200px 1fr;gap:3rem;padding:2.5rem 0;border-bottom:1px solid var(--border) }
  .exp-article:last-child { border-bottom:none }
  .exp-date { font-family:var(--font-mono);font-size:11px;color:var(--accent);margin-bottom:.5rem }
  .exp-company { font-size:14px;margin-bottom:.25rem }
  .exp-location { font-size:12px;color:var(--muted) }
  .exp-title { font-family:var(--font-serif);font-size:1.5rem;font-weight:400;margin-bottom:1rem }
  .exp-list { list-style:none;display:flex;flex-direction:column;gap:.6rem }
  .exp-item { display:flex;gap:.75rem;align-items:baseline;font-size:14px;color:var(--muted) }
  .exp-tag { font-family:var(--font-mono);font-size:10px;flex-shrink:0;margin-top:3px }

  /* ── SKILLS ── */
  .skills-section { padding:6rem 2.5rem;border-top:1px solid var(--border);background:var(--surface) }
  .skills-inner { max-width:900px;margin:0 auto }
  .skills-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:2px }
  .skill-card { background:var(--bg);padding:1.75rem;border:1px solid var(--border) }
  .skill-cat { font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:.12em;margin-bottom:1rem }
  .skill-list { list-style:none;display:flex;flex-direction:column;gap:.5rem }
  .skill-item { font-size:14px;display:flex;align-items:center;gap:8px }
  .skill-dot { width:4px;height:4px;background:var(--accent);border-radius:50%;flex-shrink:0 }

  /* ── MÉTRICAS ── */
  .metrics-section { padding:6rem 2.5rem;border-top:1px solid var(--border) }
  .metrics-inner { max-width:900px;margin:0 auto }
  .metrics-grid { display:grid;grid-template-columns:repeat(4,1fr);gap:2px }
  .metric-card { padding:2rem 1.5rem;border:1px solid var(--border);position:relative;overflow:hidden }
  .metric-bar { position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),transparent) }
  .metric-num { font-family:var(--font-serif);font-size:2.5rem;font-weight:400;color:var(--accent);margin-bottom:.75rem;line-height:1 }
  .metric-label { font-size:13px;color:var(--muted);line-height:1.5 }

  /* ── CONTACTO ── */
  .contact-section { padding:6rem 2.5rem 8rem;border-top:1px solid var(--border);background:var(--surface) }
  .contact-inner { max-width:900px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center }
  .contact-title { font-family:var(--font-serif);font-size:clamp(2rem,4vw,3.5rem);font-weight:400;line-height:1.1;margin-bottom:1.5rem }
  .contact-desc { color:var(--muted);font-size:14px;max-width:360px }
  .contact-cards { display:flex;flex-direction:column;gap:1rem }
  .contact-card { display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border:1px solid var(--border);transition:border-color .2s,background .2s }
  .contact-card:hover { border-color:var(--accent);background:rgba(200,240,100,.04) }
  .contact-card-label { font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:.12em;margin-bottom:2px }
  .contact-card-val { font-size:14px }

  /* ── FOOTER ── */
  footer { padding:2rem 2.5rem;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem }
  footer span { font-family:var(--font-mono);font-size:11px;color:var(--muted) }

  /* ── HAMBURGER ── */
  .hamburger { display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px }
  .hamburger span { width:22px;height:1.5px;background:var(--text);transition:all .3s }
  .mobile-menu { display:none;position:fixed;inset:0;background:var(--bg);z-index:99;flex-direction:column;justify-content:center;align-items:center;gap:2.5rem }
  .mobile-menu.open { display:flex }
  .mobile-menu a { font-family:var(--font-serif);font-size:2rem;color:var(--text) }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    nav { padding:1rem 1.25rem }
    .nav-links { display:none }
    .hamburger { display:flex }

    .hero { padding:0 1.25rem 4rem;min-height:100svh }
    .hero-title { font-size:clamp(2.5rem,12vw,4rem) }
    .hero-desc { font-size:14px }
    .hero-scroll { display:none }

    .about { padding:2.5rem 1.25rem;gap:2rem }
    .about-item { flex:0 0 calc(50% - 1rem) }

    .exp-section { padding:4rem 1.25rem }
    .exp-article { grid-template-columns:1fr;gap:1rem }

    .skills-section { padding:4rem 1.25rem }
    .skills-grid { grid-template-columns:repeat(2,1fr) }

    .metrics-section { padding:4rem 1.25rem }
    .metrics-grid { grid-template-columns:repeat(2,1fr) }
    .metric-num { font-size:2rem }

    .contact-section { padding:4rem 1.25rem 5rem }
    .contact-inner { grid-template-columns:1fr;gap:2.5rem }

    footer { padding:1.5rem 1.25rem;flex-direction:column;align-items:flex-start;gap:.5rem }
  }

  @media (max-width: 480px) {
    .about-item { flex:0 0 100% }
    .skills-grid { grid-template-columns:1fr }
    .metrics-grid { grid-template-columns:1fr 1fr }
    .hero-actions { flex-direction:column;align-items:flex-start }
  }
</style>

<!-- HAMBURGER MENU -->
<div class="mobile-menu" id="mobileMenu">
